# Copy this file to .env.local and fill in your values

# Required: Anthropic API key for Claude AI
ANTHROPIC_API_KEY=

# Optional: Passcode to gate all AI API actions on the site.
# Set this on Vercel (Environment Variables) — never commit the real value.
# If left empty, the tool runs in open/dev mode (no passcode required).
# Visitors must enter this code before Generate / Export / JIRA upload will work.
ACCESS_PASSCODE=

# Public URL of the portfolio site (no trailing slash).
# Set this on Vercel once the portfolio is deployed.
NEXT_PUBLIC_PORTFOLIO_URL=https://atulsharma.vercel.app
